# Database Connection URL (e.g. PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/atlas_edu

# JWT secret key for session tokens (Must be at least 16 characters)
JWT_SECRET=super-secret-key-of-at-least-16-characters-long

# === Proveedores de IA Configurados ===

# Proveedor por defecto y modelo principal
AI_DEFAULT_PROVIDER=opencode
AI_DEFAULT_MODEL=kimi-k2.5

# Opciones de allowed list (opcional, por defecto deshabilitado)
AI_ENFORCE_ALLOWLIST=false
AI_ALLOWED_MODELS=opencode:kimi-k2.5

# Listado de modelos alternativos de respaldo (separados por comas)
AI_FALLBACK_MODELS=opencode:kimi-k2.6,opencode:gpt-5.5-pro

# Configuración de Embeddings
AI_DEFAULT_EMBEDDING_PROVIDER=opencode
AI_DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
AI_ALLOWED_EMBEDDING_MODELS=opencode:text-embedding-3-small
AI_ENFORCE_EMBEDDING_ALLOWLIST=false

# --- Llaves y URLs de los Proveedores ---

# 1. OpenCode Go (Puerta de enlace Zen)
OPENCODE_GO_API_KEY=tu_api_key_aqui
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/v1

# 2. OpenAI Directo
OPENAI_API_KEY=tu_api_key_aqui

# 3. Anthropic Directo
ANTHROPIC_API_KEY=tu_api_key_aqui

# 4. Google Directo
GOOGLE_GENERATIVE_AI_API_KEY=tu_api_key_aqui

# 5. DeepSeek Directo (Opcional, configurado en src/lib/ai.ts)
DEEPSEEK_API_KEY=tu_api_key_aqui
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 6. Groq Directo (Opcional, configurado en src/lib/ai.ts)
GROQ_API_KEY=tu_api_key_aqui
GROQ_BASE_URL=https://api.groq.com/openai/v1
